# Portainer stack environment for Rauchbar staging on 65.21.2.149.
# Load these values via Portainer when deploying docker-compose.portainer.yml from Git.

ACME_EMAIL=ops@example.com
PUBLIC_BIND_IPV4=65.21.2.149
GHCR_NAMESPACE=ghcr.io/beisel-it
IMAGE_TAG=main

SITE_HOST=staging.rauchbar.genussgesellschaft-neckartal.de
ADMIN_HOST=admin.rauchbar.genussgesellschaft-neckartal.de
SITE_BASE_URL=https://staging.rauchbar.genussgesellschaft-neckartal.de
ADMIN_BASE_URL=https://admin.rauchbar.genussgesellschaft-neckartal.de
PUBLIC_APP_URL=https://staging.rauchbar.genussgesellschaft-neckartal.de

NODE_ENV=production
APP_ENV=staging
LOG_LEVEL=info

POSTGRES_DB=rauchbar
POSTGRES_USER=rauchbar
POSTGRES_PASSWORD=replace-me

SESSION_SECRET=replace-me
SCRAPER_JOB_QUEUE=scrape-staging
QUEUE_CONCURRENCY=2
WORKER_ROLE=worker

ALLOW_REAL_EMAIL_SEND=false
ALLOW_REAL_WHATSAPP_SEND=false

# Optional while real sends stay disabled.
EMAIL_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
SENTRY_DSN=
