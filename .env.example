# Local environment skeleton for Rauchbar.
# Do not put real secrets into this file. Copy to a private .env file if needed.

NODE_ENV=development
APP_ENV=local
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://rauchbar:rauchbar@localhost:5432/rauchbar
REDIS_HOST=localhost
REDIS_PORT=6379

SITE_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000

WORKER_ROLE=worker
SCRAPER_JOB_QUEUE=scrape-local
QUEUE_CONCURRENCY=1

ALLOW_REAL_EMAIL_SEND=false
ALLOW_REAL_WHATSAPP_SEND=false

SESSION_SECRET=replace-me
EMAIL_PROVIDER_API_KEY=replace-me
WHATSAPP_PROVIDER_API_KEY=replace-me
SENTRY_DSN=

