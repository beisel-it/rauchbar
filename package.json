{
  "name": "rauchbar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @rauchbar/site dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "ux:preview": "node tools/ux-preview/server.mjs",
    "ux:preview:host": "node tools/ux-preview/server.mjs --host 0.0.0.0 --port 4173",
    "ux:preview:capture": "node tools/ux-preview/capture-screenshots.mjs"
  }
}
